{
  "name": "llmui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npx concurrently \"npm:server\" \"npm:client\"",
    "server": "node server/index.js",
    "client": "npx vite",
    "build": "npx vite build",
    "preview": "npx vite preview",
    "tui": "node tui/index.js",
    "gpu-stats": "node scripts/gpu-stats-server.js",
    "test": "node --test server/tools/*.test.js",
    "postinstall": "node -e \"console.log('\\n✓ Installation complete! Run: npm run dev\\n')\""
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.4.1",
    "nanoid": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.2.1",
    "vite": "^6.0.0"
  }
}
