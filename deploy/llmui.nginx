# nginx config for LLMUI — local LLM web interface.
# Install:
#   sudo cp deploy/llmui.nginx /etc/nginx/sites-available/llmui
#   sudo ln -sf /etc/nginx/sites-available/llmui /etc/nginx/sites-enabled/llmui
#   sudo nginx -t && sudo systemctl reload nginx

server {
    listen 8446 ssl;
    server_name box.tailde6c83.ts.net;

    ssl_certificate     /var/lib/tailscale/certs/box.tailde6c83.ts.net.crt;
    ssl_certificate_key /var/lib/tailscale/certs/box.tailde6c83.ts.net.key;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;

    add_header Strict-Transport-Security "max-age=63072000" always;
    add_header X-Frame-Options "SAMEORIGIN";
    add_header X-Content-Type-Options "nosniff";
    add_header Referrer-Policy "strict-origin-when-cross-origin";

    location / {
        proxy_pass         http://127.0.0.1:3000;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto https;

        # WebSocket support (Vite HMR)
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";

        # SSE / streaming LLM responses — disable buffering and extend timeout
        proxy_buffering    off;
        proxy_read_timeout 300s;
    }
}
